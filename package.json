{
  "name": "sui3",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 8333",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
